FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         100;

deltaT          0.01;

writeControl    timeStep;

writeInterval   50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    forceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");

        patches         (box);

        rho             rhoInf;
        rhoInf          1;

        magUInf         1;

        CofR            (0 0 0);

        dragDir         (1 0 0);
        liftDir         (0 1 0);
        pitchAxis       (0 0 1);

        lRef            2;
        Aref            2;

        writeControl    timeStep;
        writeInterval   50;

        log             true;
    }
}

